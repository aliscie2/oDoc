# oDoc Environment Configuration
# Copy this file to .env and update with your values



# Canister IDs (Generated automatically during deployment)
VITE_INTERNET_IDENTITY=
VITE_BACKEND_CANISTER_ID=
VITE_FRONTEND_CANISTER_ID=
VITE_CANISTER_ID_CKUSDC_LEDGER=

# =============================================================================
# Development Configuration
# =============================================================================
VITE_TEST_ENV=backend
VITE_PUBLIC_BASE_PATH=
SECRET=your_secret_key_here
ODOC_CEO_ID=

# Pocket IC (for testing)
POCKET_IC_BIN=/path/to/pocket-ic
VITE_POCKET_IC_BIN=/path/to/pocket-ic

# Development Tools
AIDER_COMMAND=aider --model sonnet --anthropic-api-key YOUR_KEY
ZEROSTEP_TOKEN=

# =============================================================================
# AI API Keys
# =============================================================================
# Anthropic Claude
VITE_ANTHROPIC_API_KEY=sk-ant-api03-your_key_here
VITE_ANTHROPIC_SECRET_KEY=sk-ant-admin01-your_secret_here

# Google AI
VITE_GEMINI_API_KEY=your_gemini_key_here
VITE_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
VITE_GOOGLE_API_KEY=your_google_api_key
VITE_GOOGLE_CLIENT_SECRET=your_google_client_secret

# DeepSeek
VITE_DEEPSEEK_API_KEY=sk-your_deepseek_key_here

# Hugging Face
VITE_HUGING_FACE_TOKEN=hf_your_token_here

# =============================================================================
# Email Services
# =============================================================================
# EmailJS
VITE_REACT_APP_EMAILJS_SERVICE_ID=service_your_id
VITE_REACT_APP_EMAILJS_USER_ID=your_user_id
VITE_REACT_APP_EMAILJS_TEMPLATE_ID=template_your_id

# Gmail Integration
VITE_GMAIL_AUTH_CLIENT_ID=your_gmail_client_id

# Mailgun
VITE_MAILGUN_KEY=pubkey-your_public_key
VITE_MAINGUN_SECRET_KEY=your_secret_key

# Mailjet
VITE_MAILJET_KEY=your_mailjet_key
VITE_MAILJET_SECRET_KEY=your_mailjet_secret

# Brevo (formerly Sendinblue)
VITE_BREVO_SECRET_KEY=xsmtpsib-your_secret_key

# MailTrap
VITE_MAIL_TRAP=your_mailtrap_token

# =============================================================================
# Communication & Monitoring
# =============================================================================
# Telegram Bot
VITE_PUBLIC_TELEGRAM_BOT_TOKEN=your_bot_token:your_bot_hash

# Sentry Error Monitoring
VITE_SENTRY_DNS=https://your_sentry_dsn@sentry.io/project_id

# =============================================================================
# Instructions
# =============================================================================
# 1. Copy this file to .env in your project root
# 2. Run 'make deploy-all' - this will auto-populate canister IDs
# 3. Add your API keys for the services you want to use
# 4. Optional services can be left empty - the app will work without them
#
# Required for basic functionality:
# - DFX configuration (auto-generated)
# - At least one AI API key (Anthropic, Gemini, or DeepSeek)
#
# Optional services:
# - Email services (for notifications)
# - Telegram bot (for integrations)
# - Sentry (for error monitoring)